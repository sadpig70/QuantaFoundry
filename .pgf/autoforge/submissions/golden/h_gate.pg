```python id=golden
import numpy as np
# Hadamard: H = (1/sqrt(2)) * [[1, 1], [1, -1]]
# Basis ordering (big-endian): |0> -> column 0, |1> -> column 1.
# H|0> = (|0> + |1>)/sqrt(2),  H|1> = (|0> - |1>)/sqrt(2)
_inv_sqrt2 = 1.0 / np.sqrt(2.0)
golden = np.array([[ _inv_sqrt2,  _inv_sqrt2],
                   [ _inv_sqrt2, -_inv_sqrt2]], dtype=complex)  # shape (2,2)
```
