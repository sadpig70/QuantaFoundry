{"id": "select_prepare4", "n_sys": 3, "n_anc": 0}
```
```python id=app_golden
import numpy as np
I2 = np.eye(2, dtype=complex)
X = np.array([[0, 1], [1, 0]], dtype=complex)
Hd = np.array([[1, 1], [1, -1]], dtype=complex) / np.sqrt(2)
S = np.diag([1, 1j]).astype(complex)
Sd = S.conj().T
NQ = 3
def kr(*m):
    r = m[0]
    for x in m[1:]:
        r = np.kron(r, x)
    return r
def emb(op, q):
    return kr(*[op if i == q else I2 for i in range(NQ)])
def bits(x):
    return [(x >> (NQ - 1 - i)) & 1 for i in range(NQ)]
def frombits(b):
    v = 0
    for i in range(NQ):
        v |= (b[i] & 1) << (NQ - 1 - i)
    return v
def ccx(c1, c2, t):
    M = np.zeros((8, 8), dtype=complex)
    for x in range(8):
        b = bits(x)
        if b[c1] and b[c2]:
            b = b[:]; b[t] ^= 1
        M[frombits(b), x] = 1.0
    return M
def ccz(c1, c2, c3):
    M = np.eye(8, dtype=complex)
    for x in range(8):
        b = bits(x)
        if b[c1] and b[c2] and b[c3]:
            M[x, x] = -1.0
    return M
gates = [emb(Hd, 0), emb(Hd, 1),                                   # PREPARE
         emb(X, 0), ccx(0, 1, 2), emb(X, 0),                        # 01 -> X
         emb(X, 1), emb(Sd, 2), ccx(0, 1, 2), emb(S, 2), emb(X, 1), # 10 -> Y = S·X·S†
         ccz(0, 1, 2),                                              # 11 -> Z
         emb(Hd, 0), emb(Hd, 1)]                                    # UNPREPARE
golden = np.eye(8, dtype=complex)
for G in gates:
    golden = G @ golden
```
