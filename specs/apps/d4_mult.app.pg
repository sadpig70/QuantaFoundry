{"id": "d4_mult", "n_sys": 6, "n_anc": 0}
```
```python id=app_golden
import numpy as np
NQ = 6
DIM = 64
def bits(x):
    return [(x >> (NQ - 1 - i)) & 1 for i in range(NQ)]
def frombits(b):
    v = 0
    for i in range(NQ):
        v |= (b[i] & 1) << (NQ - 1 - i)
    return v
def semantics(g, h):
    """(a,b)(c,d)=(a+(−1)^b c mod 4, b⊕d) — 회로 의미(전 64 상태 유효)."""
    a1, a0, bb = g
    c1, c0, dd = h
    dd ^= bb                       # CNOT b→d
    if bb:                         # −c mod 4 = 1↔3 스왑 = c1 ⊕= c0 (b-제어 toffoli)
        c1 ^= c0
    c1 ^= (a0 & c0)                # carry (가산 전 c0 사용, toffoli)
    c0 ^= a0                       # CNOT
    c1 ^= a1                       # CNOT
    return [a1, a0, bb, c1, c0, dd]
golden = np.zeros((DIM, DIM), dtype=complex)
for x in range(DIM):
    b = bits(x)
    golden[frombits(semantics(b[:3], b[3:])), x] = 1.0 + 0.0j
```
