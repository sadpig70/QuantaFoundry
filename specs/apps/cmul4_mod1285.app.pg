# cmul4_mod1285 — controlled (×4 mod 1285) on 11 work qubits (12q, q0=control). genskill=modmul_synth@1.
# golden=산술 순열(독립), plan=6815 gates = MMD reversible synthesis → 봉인 ['c10x', 'c11x', 'c3x', 'c4x', 'c5x', 'c6x', 'c7x', 'c8x', 'c9x', 'toffoli'] (≤11 control, no MatrixGate).
```json id=app_meta
{"id": "cmul4_mod1285", "n_sys": 12, "n_anc": 0}
```
```python id=app_golden
import numpy as np
a=4; N=1285; nq=12
dim=1<<nq; wb=nq-1
golden=np.zeros((dim,dim),dtype=complex)
for s in range(dim):
    if (s>>(nq-1))&1==0: golden[s,s]=1
    else:
        w=s&((1<<wb)-1); nw=(a*w)%N if w<N else w
        golden[(1<<(nq-1))|nw, s]=1
```
