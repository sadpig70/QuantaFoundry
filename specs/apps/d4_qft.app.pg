```python id=app_golden
import numpy as np
# 기약표현 공식으로 직접 구성 (C4 독립참조): 행=irrep 행렬원소, 열=g=(a,b)
golden = np.zeros((8, 8), dtype=complex)
for a in range(4):
    for b in range(2):
        x = (a << 1) | b
        golden[0, x] = 1 / np.sqrt(8)                          # χ₁ (trivial)
        golden[1, x] = (-1) ** b / np.sqrt(8)                  # χ₂ (sign s)
        golden[4, x] = (-1) ** a / np.sqrt(8)                  # χ₃ (sign r)
        golden[5, x] = (-1) ** (a + b) / np.sqrt(8)            # χ₄
        golden[2, x] = (1j ** a) / 2 if b == 0 else 0          # ρ₀₀
        golden[3, x] = (1j ** a) / 2 if b == 1 else 0          # ρ₀₁
        golden[6, x] = ((-1j) ** a) / 2 if b == 0 else 0       # ρ₁₁
        golden[7, x] = ((-1j) ** a) / 2 if b == 1 else 0       # ρ₁₀
```
