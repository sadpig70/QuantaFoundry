```python id=app_golden
import numpy as np
def _pp(n,cn):
    U=np.zeros((1<<n,1<<n),complex)
    for s in range(1<<n):
        o=s
        for c,t in cn:
            cb=(o>>(n-1-c))&1; tb=(o>>(n-1-t))&1; p=n-1-t
            o=(o&~(1<<p))|((tb^cb)<<p)
        U[o,s]=1.0
    return U
def _h(n,qs):
    H=np.array([[1,1],[1,-1]],complex)/np.sqrt(2); U=np.array([[1.0+0j]]); qs=set(qs)
    for q in range(n):
        U=np.kron(U,H if q in qs else np.eye(2,dtype=complex))
    return U
golden=_h(3,[0,1,2])@_pp(3,[(0,1),(0,2)])
```
