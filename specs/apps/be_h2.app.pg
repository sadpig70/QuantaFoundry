```python id=app_golden
import numpy as np
I2 = np.eye(2, dtype=complex)
X = np.array([[0, 1], [1, 0]], dtype=complex)
Z = np.array([[1, 0], [0, -1]], dtype=complex)
Hd = np.array([[1, 1], [1, -1]], dtype=complex) / np.sqrt(2)
S = np.diag([1, 1j]).astype(complex)
Sd = S.conj().T
NQ = 4
def kr(*m):
    r = m[0]
    for x in m[1:]:
        r = np.kron(r, x)
    return r
def emb(op, q):
    return kr(*[op if i == q else I2 for i in range(NQ)])
def bits(x):
    return [(x >> (NQ - 1 - i)) & 1 for i in range(NQ)]
def frombits(b):
    x = 0
    for i in range(NQ):
        x |= (b[i] & 1) << (NQ - 1 - i)
    return x
def toffoli(c1, c2, t):
    M = np.zeros((16, 16), dtype=complex)
    for x in range(16):
        b = bits(x)
        if b[c1] and b[c2]:
            b = b[:]; b[t] ^= 1
        M[frombits(b), x] = 1.0
    return M
def ccz(c1, c2, c3):
    M = np.eye(16, dtype=complex)
    for x in range(16):
        b = bits(x)
        if b[c1] and b[c2] and b[c3]:
            M[x, x] = -1.0
    return M
def cz(a, b_):
    M = np.eye(16, dtype=complex)
    for x in range(16):
        bb = bits(x)
        if bb[a] and bb[b_]:
            M[x, x] = -1.0
    return M
gates = [emb(Hd, 0), emb(Hd, 1),
         emb(X, 0), emb(X, 1), cz(0, 1), emb(X, 0), emb(X, 1),          # 00 -> -I
         emb(X, 0), ccz(0, 1, 2), ccz(0, 1, 3), emb(X, 0),             # 01 -> Z2Z3
         emb(X, 1), toffoli(0, 1, 2), toffoli(0, 1, 3), emb(X, 1),     # 10 -> X2X3
         emb(Sd, 2), emb(Sd, 3), toffoli(0, 1, 2), toffoli(0, 1, 3), emb(S, 2), emb(S, 3),  # 11 -> Y2Y3
         emb(Hd, 0), emb(Hd, 1)]
golden = np.eye(16, dtype=complex)
for G in gates:
    golden = G @ golden
```
