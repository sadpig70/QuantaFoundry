```python id=app_golden
import numpy as np
NQ = 6
DIM = 64
def bits(x):
    return [(x >> (NQ - 1 - i)) & 1 for i in range(NQ)]
def frombits(b):
    v = 0
    for i in range(NQ):
        v |= (b[i] & 1) << (NQ - 1 - i)
    return v
def semantics(g, h):
    """(a,b)(c,d)=(a+(−1)^b c mod3, b⊕d) 의 회로 의미(invalid 계약 포함)."""
    a1, a0, bb = g
    c1, c0, dd = h
    dd ^= bb                                   # CNOT b→d
    if bb:                                     # fredkin: mod-3 부정 = c1↔c0 스왑 (11 고정)
        c1, c0 = c0, c1
    if (a1, a0) == (0, 1):                     # +1 mod 3: t01 후 t02
        if c1 == 0:
            c0 ^= 1
        if c0 == 0:
            c1 ^= 1
    if (a1, a0) == (1, 0):                     # +2 mod 3: t02 후 t01 (역사이클)
        if c0 == 0:
            c1 ^= 1
        if c1 == 0:
            c0 ^= 1
    return [a1, a0, bb, c1, c0, dd]
golden = np.zeros((DIM, DIM), dtype=complex)
for x in range(DIM):
    b = bits(x)
    golden[frombits(semantics(b[:3], b[3:])), x] = 1.0 + 0.0j
```
