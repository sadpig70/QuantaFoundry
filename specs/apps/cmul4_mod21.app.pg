```python id=app_golden
import numpy as np
from functools import reduce
N=21
def cm(a):
    M=np.zeros((64,64),dtype=complex)
    for s in range(64):
        if (s>>5)&1==0: M[s,s]=1
        else:
            w=s&31; M[(1<<5)|((a*w)%N if w<N else w), s]=1
    return M
golden=cm(4)
```
