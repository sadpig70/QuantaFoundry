```python id=app_golden
import numpy as np
NQ = 4                     # q0,q1 = address ; q2,q3 = data (big-endian)
DATA = [1, 2, 3, 0]        # data[i] = (i+1) mod 4 — 독립 산술 참조(C4)
def bits(x):
    return [(x >> (NQ - 1 - i)) & 1 for i in range(NQ)]
def frombits(b):
    x = 0
    for i in range(NQ):
        x |= (b[i] & 1) << (NQ - 1 - i)
    return x
golden = np.zeros((16, 16), dtype=complex)
for x in range(16):
    b = bits(x)
    i = (b[0] << 1) | b[1]
    d = (b[2] << 1) | b[3]
    nd = d ^ DATA[i]
    golden[frombits([b[0], b[1], (nd >> 1) & 1, nd & 1]), x] = 1.0 + 0.0j
```
