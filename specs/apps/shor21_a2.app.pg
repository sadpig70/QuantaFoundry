```python id=app_golden
import numpy as np
n=12; N=21
H=np.array([[1,1],[1,-1]],dtype=complex)/np.sqrt(2)
M=128; w=np.exp(2j*np.pi/M)
QFT=np.array([[w**(a*b) for b in range(M)] for a in range(M)],dtype=complex)/np.sqrt(M); IQFT=QFT.conj().T
def cmul(a):
    g=np.zeros((64,64),dtype=complex)
    for s in range(64):
        if (s>>5)&1==0: g[s,s]=1
        else:
            v=s&31; g[(1<<5)|((a*v)%N if v<N else v),s]=1
    return g
def apply(U,targets,T):
    k=len(targets); gg=U.reshape([2]*k+[2]*k)
    T=np.tensordot(gg,T,axes=(list(range(k,2*k)),targets))
    return np.moveaxis(T,list(range(k)),targets)
T=np.eye(1<<n,dtype=complex).reshape([2]*n+[1<<n])
for j in range(7): T=apply(H,[j],T)
powa={0:16,1:4,2:16,3:4,4:16,5:4,6:2}
for j in range(7): T=apply(cmul(powa[j]),[j,7,8,9,10,11],T)
T=apply(IQFT,[0,1,2,3,4,5,6],T)
golden=T.reshape(1<<n,1<<n)
```
