# cmul256_mod635 — controlled (×256 mod 635) on 10 work qubits (11q, q0=control). genskill=modmul_synth@1.
# golden=산술 순열(독립), plan=4633 gates = MMD reversible synthesis → 봉인 ['c10x', 'c3x', 'c4x', 'c5x', 'c6x', 'c7x', 'c8x', 'c9x', 'toffoli'] (≤10 control, no MatrixGate).
```json id=app_meta
{"id": "cmul256_mod635", "n_sys": 11, "n_anc": 0}
```
```python id=app_golden
import numpy as np
a=256; N=635; nq=11
dim=1<<nq; wb=nq-1
golden=np.zeros((dim,dim),dtype=complex)
for s in range(dim):
    if (s>>(nq-1))&1==0: golden[s,s]=1
    else:
        w=s&((1<<wb)-1); nw=(a*w)%N if w<N else w
        golden[(1<<(nq-1))|nw, s]=1
```
