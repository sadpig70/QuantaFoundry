```python id=app_golden
import numpy as np
from functools import reduce
I = np.eye(2, dtype=complex)
Hd = np.array([[1, 1], [1, -1]], dtype=complex) / np.sqrt(2)
NQ = 5
DIM = 32
def kr(*m):
    return reduce(np.kron, m)
def emb(op, q):
    return kr(*[op if i == q else I for i in range(NQ)])
def bits(x):
    return [(x >> (NQ - 1 - i)) & 1 for i in range(NQ)]
def frombits(b):
    v = 0
    for i in range(NQ):
        v |= (b[i] & 1) << (NQ - 1 - i)
    return v
def cnot(c, t):
    M = np.zeros((DIM, DIM), dtype=complex)
    for x in range(DIM):
        b = bits(x)
        b = b[:]; b[t] ^= b[c]
        M[frombits(b), x] = 1.0
    return M
def cz(a, b_):
    M = np.eye(DIM, dtype=complex)
    for x in range(DIM):
        bb = bits(x)
        if bb[a] and bb[b_]:
            M[x, x] = -1.0
    return M
gates = [cnot(0, 1), cnot(0, 2), cnot(0, 3), cnot(0, 4),
         emb(Hd, 0), emb(Hd, 1), emb(Hd, 2), emb(Hd, 3), emb(Hd, 4),
         cz(0, 1), cz(1, 2), cz(2, 3), cz(3, 4), cz(4, 0)]
golden = np.eye(DIM, dtype=complex)
for G in gates:
    golden = G @ golden
```
